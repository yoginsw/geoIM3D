{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for geoIM3D Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    },
    {
      "comment": "Approved geocoding hosts routed through the native HTTP client to bypass WebView CORS and send the required User-Agent. Keep this allowlist in sync with the geocoding provider registry. Share and collaboration hosts remain absent until deployment endpoints are approved.",
      "identifier": "http:default",
      "allow": [
        { "url": "https://nominatim.openstreetmap.org/*" },
        { "url": "https://api.geocode.earth/*" },
        { "url": "https://geocode.arcgis.com/*" },
        { "url": "https://api.mapbox.com/*" },
        { "url": "https://maps.googleapis.com/*" }
      ]
    }
  ]
}
