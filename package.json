{
  "name": "geolibre",
  "private": true,
  "version": "0.9.0",
  "description": "GeoLibre: a lightweight, cloud-native GIS platform for visualizing, exploring, and analyzing geospatial data across desktop and web environments, with a responsive layout for mobile screens",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "trustedDependencies": [
    "@google/genai",
    "core-js",
    "protobufjs"
  ],
  "scripts": {
    "dev": "npm run dev -w geolibre-desktop",
    "build": "npm run build -w geolibre-desktop",
    "typecheck": "npm run build",
    "test": "npm run test:frontend",
    "test:frontend": "node --import tsx --test tests/*.test.ts",
    "test:backend": "python -m pytest backend/geolibre_server/tests",
    "test:worker": "npm run typecheck -w geolibre-viewer-worker",
    "check:rust": "cargo check --manifest-path apps/geolibre-desktop/src-tauri/Cargo.toml",
    "ci": "npm run build && npm run test:frontend && npm run test:worker && npm run test:backend && npm run check:rust",
    "tauri": "npm run tauri -w geolibre-desktop",
    "tauri:dev": "npm run tauri dev -w geolibre-desktop",
    "tauri:build": "node scripts/tauri-build.mjs",
    "msix:build": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-msix.ps1"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.22.4"
  }
}
